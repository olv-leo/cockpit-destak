# ─── Variáveis Vercel (frontend) ───────────────────────────────────────────────

# Código de acesso ao cockpit (defina um código forte, ex: uma frase ou UUID)
ACCESS_CODE=seu-codigo-de-acesso-aqui

# GitHub Personal Access Token com escopos: repo, workflow
# Criar em: GitHub > Settings > Developer Settings > Personal Access Tokens
GITHUB_TOKEN=ghp_...

# Conta e repositório do GitHub
GITHUB_OWNER=seu-usuario-ou-org
GITHUB_REPO=cockpit-destak


# ─── Secrets GitHub Actions (nunca colocar no Vercel) ─────────────────────────

# Service Account JSON completo do Google Cloud (minify em uma linha antes de adicionar)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Conexão PostgreSQL
# POSTGRES_HOST=seu-host-postgres
# POSTGRES_DB=nome-do-banco
# POSTGRES_USER=usuario
# POSTGRES_PASSWORD=sua-senha-aqui

# IDs das planilhas Google Sheets
# SHEETS_ID_ORIGINAL=id-da-planilha-manejos-original
# SHEETS_ID_TRATADA=id-da-planilha-manejos-tratada

# ─── Azure AD / Power BI ──────────────────────────────────────────────────────
# Registre um app em portal.azure.com > Azure Active Directory > Registros de aplicativo
# Redirect URI: https://seu-app.vercel.app/api/auth/powerbi/callback  (+ localhost para dev)
# Escopos: openid, profile, offline_access, https://analysis.windows.net/powerbi/api/Dataset.ReadWrite.All

# Frontend (login OAuth do usuário)
AZURE_TENANT_ID=seu-tenant-id
AZURE_CLIENT_ID=seu-client-id

# Dataset a verificar/atualizar
POWERBI_WORKSPACE_ID=id-do-workspace-power-bi
POWERBI_DATASET_ID=id-do-dataset-power-bi

# GitHub Actions (service principal — adicionar como GitHub Secrets)
# AZURE_CLIENT_SECRET=segredo-do-app-azure
# (AZURE_TENANT_ID, AZURE_CLIENT_ID, POWERBI_WORKSPACE_ID, POWERBI_DATASET_ID — mesmos valores acima)
