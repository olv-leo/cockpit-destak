# ─── Variáveis Vercel (frontend) ───────────────────────────────────────────────

# Código de acesso ao cockpit (defina um código forte, ex: uma frase ou UUID)
ACCESS_CODE=seu-codigo-de-acesso-aqui

# GitHub Personal Access Token com escopos: repo, workflow
# Criar em: GitHub > Settings > Developer Settings > Personal Access Tokens
GITHUB_TOKEN=ghp_...

# Conta e repositório do GitHub
GITHUB_OWNER=seu-usuario-ou-org
GITHUB_REPO=cockpit-destak


# ─── Secrets GitHub Actions (nunca colocar no Vercel) ─────────────────────────

# Service Account JSON completo do Google Cloud (minify em uma linha antes de adicionar)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Conexão PostgreSQL
# POSTGRES_HOST=seu-host-postgres
# POSTGRES_DB=nome-do-banco
# POSTGRES_USER=usuario
# POSTGRES_PASSWORD=sua-senha-aqui

# IDs das planilhas Google Sheets
# SHEETS_ID_ORIGINAL=id-da-planilha-manejos-original
# SHEETS_ID_TRATADA=id-da-planilha-manejos-tratada
